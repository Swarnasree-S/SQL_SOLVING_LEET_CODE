
select 
    d.name as department,
    e.name as employee,
    e.salary
from employee e
join ( 
    select 
        max(salary) as salary,
        departmentid
    from employee
    group by departmentid 
)t
ON e.departmentid = t.departmentid
AND e.salary = t.salary
join department d
on e.departmentid=d.id


notes:
---------
Best Practice
Condition Type	Use
------------------
Table matching	- ON
Row filtering	- WHERE

